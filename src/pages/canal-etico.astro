---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout titulo="Canal Ético" descripcion="Canal ético y de cumplimiento de INACONS — reporte confidencial y seguro">

  <style slot="head">
    .guarantees-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3px; margin-top: 48px; }
    .guarantee-item {
      background: var(--c-bg-white); border: 1px solid var(--c-border-light);
      padding: 28px 24px; display: flex; align-items: flex-start; gap: 16px;
      transition: box-shadow .22s, border-color .22s;
    }
    .guarantee-item:hover { border-color: var(--c-secondary); box-shadow: var(--shadow-card); }
    .guarantee-icon {
      width: 44px; height: 44px; background: var(--c-bg-muted);
      border-radius: 2px; display: flex; align-items: center; justify-content: center;
      color: var(--c-secondary); flex-shrink: 0;
      transition: background .22s, color .22s;
    }
    .guarantee-item:hover .guarantee-icon { background: var(--c-secondary); color: #fff; }
    .guarantee-title { font-size: 0.88rem; font-weight: 700; color: var(--c-text-heading); margin-bottom: 4px; }
    .guarantee-desc { font-size: 0.80rem; color: var(--c-text-muted); line-height: 1.65; }
    .terms-wrap { max-width: 800px; margin: 0 auto; }
    .terms-box {
      border: 1.5px solid var(--c-border); border-radius: 2px;
      padding: 28px 32px; height: 280px; overflow-y: auto;
      background: var(--c-bg-muted); margin-bottom: 24px;
      font-size: 0.875rem; line-height: 1.8; color: var(--c-text-muted);
    }
    .terms-box::-webkit-scrollbar { width: 5px; }
    .terms-box::-webkit-scrollbar-track { background: var(--c-border-light); }
    .terms-box::-webkit-scrollbar-thumb { background: var(--c-secondary); border-radius: 2px; }
    .terms-box h3 {
      font-size: 0.80rem; font-weight: 700; letter-spacing: 0.5px;
      color: var(--c-primary); margin: 20px 0 6px; text-transform: uppercase;
    }
    .terms-box h3:first-child { margin-top: 0; }
    .terms-box p { margin-bottom: 0; }
    .terms-accept {
      display: flex; align-items: center; gap: 14px;
      padding: 20px 24px;
      border: 1.5px solid var(--c-border); border-radius: 2px;
      cursor: pointer; transition: border-color .22s, background .22s;
      background: var(--c-bg-white); user-select: none;
    }
    .terms-accept:hover { border-color: var(--c-secondary); background: rgba(27,82,120,0.03); }
    .terms-accept input[type="checkbox"] { display: none; }
    .check-box {
      width: 22px; height: 22px;
      border: 2px solid var(--c-border); border-radius: 2px;
      flex-shrink: 0; display: flex; align-items: center; justify-content: center;
      transition: border-color .22s, background .22s; position: relative;
    }
    .terms-accept:has(input:checked) .check-box { border-color: var(--c-secondary); background: var(--c-secondary); }
    .terms-accept:has(input:checked) .check-box::after {
      content: ''; width: 5px; height: 9px;
      border: 2px solid #fff; border-top: none; border-left: none;
      transform: rotate(45deg) translateY(-1px); display: block;
    }
    .check-label { font-size: 0.875rem; font-weight: 600; color: var(--c-text-heading); line-height: 1.4; }
    .terms-accept:has(input:checked) .check-label { color: var(--c-secondary); }
    #channelsSection { display: none; }
    .channels-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3px; }
    .channel-card {
      background: var(--c-bg-white); border: 1px solid var(--c-border-light);
      padding: 36px 28px; display: flex; flex-direction: column;
      position: relative; overflow: hidden;
      transition: box-shadow .25s, transform .25s;
    }
    .channel-card::before {
      content: ''; position: absolute; top: 0; left: 0; width: 0; height: 3px;
      background: var(--c-secondary); transition: width .35s ease;
    }
    .channel-card:hover { box-shadow: var(--shadow-card-hover); transform: translateY(-4px); }
    .channel-card:hover::before { width: 100%; }
    .channel-icon-wrap {
      width: 52px; height: 52px; background: var(--c-bg-muted); border-radius: 2px;
      display: flex; align-items: center; justify-content: center;
      color: var(--c-secondary); margin-bottom: 18px;
      transition: background .25s, color .25s;
    }
    .channel-card:hover .channel-icon-wrap { background: var(--c-secondary); color: #fff; }
    .channel-name { font-size: 0.95rem; font-weight: 700; color: var(--c-text-heading); margin-bottom: 10px; line-height: 1.3; }
    .channel-desc { font-size: 0.83rem; color: var(--c-text-muted); line-height: 1.75; flex: 1; margin-bottom: 24px; }
    .channel-btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 7px;
      padding: 11px 20px;
      font-family: 'Montserrat', sans-serif;
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase;
      text-decoration: none;
      border: 1.5px solid var(--c-secondary); color: var(--c-secondary);
      border-radius: 2px; transition: background .22s, color .22s; margin-top: auto;
    }
    .channel-btn:hover { background: var(--c-secondary); color: #fff; }
    @media (max-width: 768px) {
      .guarantees-grid { grid-template-columns: 1fr; }
      .channels-grid { grid-template-columns: 1fr; }
    }
    @media (min-width: 769px) and (max-width: 1023px) {
      .channels-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>

  <!-- HERO -->
  <section class="page-hero page-hero--sm">
    <div class="page-hero-bg" style="background-image: url('/assets/imagenes/home_about.webp')"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content" data-aos="fade-up" data-aos-duration="800">
      <nav class="breadcrumb">
        <a href="/">Inicio</a>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-current">Canal Ético</span>
      </nav>
      <h1 class="page-hero-title">Canal Ético y<br>de Cumplimiento</h1>
      <p class="page-hero-subtitle">Tu voz es segura — integridad no negociable</p>
    </div>
  </section>

  <!-- ① GARANTÍAS -->
  <section class="sec sec--muted">
    <div class="container">
      <div class="sh sh--center sh--medium" data-aos="fade-up">
        <p class="sh-label">Integridad y Confianza</p>
        <h2 class="sh-title">Un canal seguro y confidencial</h2>
        <p class="sh-desc">En INACONS S.R.L, nuestra integridad no es negociable. Este canal está diseñado para que colaboradores, clientes y proveedores puedan reportar cualquier actividad que vulnere nuestra ética.</p>
      </div>
      <div class="guarantees-grid">
        <div class="guarantee-item" data-aos="fade-up" data-aos-delay="80">
          <div class="guarantee-icon"><i data-lucide="eye-off" style={{ width: "22px", height: "22px" }}></i></div>
          <div>
            <p class="guarantee-title">Anonimato Total</p>
            <p class="guarantee-desc">Puedes reportar de forma completamente anónima. Tu identidad nunca será revelada sin tu consentimiento explícito.</p>
          </div>
        </div>
        <div class="guarantee-item" data-aos="fade-up" data-aos-delay="160">
          <div class="guarantee-icon"><i data-lucide="shield-check" style={{ width: "22px", height: "22px" }}></i></div>
          <div>
            <p class="guarantee-title">Protección contra Represalias</p>
            <p class="guarantee-desc">Queda terminantemente prohibida cualquier represalia contra quien use este canal de buena fe.</p>
          </div>
        </div>
        <div class="guarantee-item" data-aos="fade-up" data-aos-delay="240">
          <div class="guarantee-icon"><i data-lucide="users" style={{ width: "22px", height: "22px" }}></i></div>
          <div>
            <p class="guarantee-title">Comité Especializado</p>
            <p class="guarantee-desc">Todas las comunicaciones son gestionadas por un Comité de Investigación independiente y especializado.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ② TÉRMINOS -->
  <section class="sec sec--white">
    <div class="container">
      <div class="sh sh--center sh--medium" data-aos="fade-up" style="margin-bottom:36px;">
        <p class="sh-label">Paso previo</p>
        <h2 class="sh-title">Términos y Condiciones de Uso</h2>
        <p class="sh-desc">Lee atentamente los términos antes de acceder a los canales de reporte.</p>
      </div>
      <div class="terms-wrap" data-aos="fade-up">
        <div class="terms-box">
          <h3>1. Objetivo del Canal</h3>
          <p>El Canal Ético de INACONS es el medio oficial para reportar conductas que puedan implicar la comisión de irregularidades o actos contrarios a la ley, al Código Ético o a las normas internas de la compañía.</p>
          <h3>2. Confidencialidad y Anonimato</h3>
          <p>INACONS garantiza la máxima confidencialidad en la gestión de las comunicaciones recibidas. Si el denunciante lo desea, el reporte puede realizarse de forma totalmente anónima. La identidad del informante no será revelada sin su consentimiento explícito, salvo obligación legal.</p>
          <h3>3. Garantía de Indemnidad</h3>
          <p>Queda terminantemente prohibida cualquier forma de represalia contra las personas que utilicen este canal de buena fe. INACONS tomará las medidas necesarias para proteger a los denunciantes.</p>
          <h3>4. Tratamiento de Datos Personales</h3>
          <p>Los datos personales facilitados serán tratados por INACONS con la finalidad de gestionar las comunicaciones recibidas e investigar los hechos denunciados.</p>
          <h3>5. Responsabilidad del Usuario</h3>
          <p>El usuario garantiza que los datos personales y la información proporcionada son verdaderos, exactos y completos. Las denuncias falsas realizadas con mala fe podrán ser objeto de sanciones disciplinarias o acciones legales.</p>
        </div>
        <label class="terms-accept">
          <input type="checkbox" id="termsCheckbox">
          <span class="check-box"></span>
          <span class="check-label">He leído y acepto los términos y condiciones de uso del Canal Ético</span>
        </label>
      </div>
    </div>
  </section>

  <!-- ③ CANALES (oculto hasta aceptar) -->
  <section class="sec sec--muted" id="channelsSection">
    <div class="container">
      <div class="sh sh--center sh--medium" data-aos="fade-up">
        <p class="sh-label">Canales Disponibles</p>
        <h2 class="sh-title">Seleccione el canal correspondiente</h2>
        <p class="sh-desc">Elige la opción que mejor se ajuste a tu reporte. Todos los canales son confidenciales.</p>
      </div>
      <div class="channels-grid">
        <div class="channel-card" data-aos="fade-up" data-aos-delay="80">
          <div class="channel-icon-wrap"><i data-lucide="help-circle" style={{ width: "24px", height: "24px" }}></i></div>
          <h3 class="channel-name">Canal de Consultas</h3>
          <p class="channel-desc">Tu tranquilidad es nuestra prioridad. Espacio diseñado para absolver dudas de colaboradores y socios estratégicos.</p>
          <a href="https://formularios-inacons.bitrix24.site/canal-consulta/" target="_blank" class="channel-btn">
            Ingresar al formulario <i data-lucide="external-link" style={{ width: "13px", height: "13px" }}></i>
          </a>
        </div>
        <div class="channel-card" data-aos="fade-up" data-aos-delay="140">
          <div class="channel-icon-wrap"><i data-lucide="alert-triangle" width={24} height={24}></i></div>
          <h3 class="channel-name">Canal de Denuncias</h3>
          <p class="channel-desc">Tolerancia cero al soborno. Si detectas cualquier acto que comprometa nuestra integridad, repórtalo aquí.</p>
          <a href="https://formularios-inacons.bitrix24.site/canal-denuncia/" target="_blank" class="channel-btn">
            Ingresar al formulario <i data-lucide="external-link" style={{ width: "13px", height: "13px" }}></i>
          </a>
        </div>
        <div class="channel-card" data-aos="fade-up" data-aos-delay="200">
          <div class="channel-icon-wrap"><i data-lucide="lightbulb" style={{ width: "24px", height: "24px" }}></i></div>
          <h3 class="channel-name">Canal de Sugerencias</h3>
          <p class="channel-desc">Crecemos juntos. Valoramos tus ideas para fortalecer nuestra mejora continua.</p>
          <a href="https://formularios-inacons.bitrix24.site/canal-sugerencia/" target="_blank" class="channel-btn">
            Ingresar al formulario <i data-lucide="external-link" style={{ width: "13px", height: "13px" }}></i>
          </a>
        </div>
        <div class="channel-card" data-aos="fade-up" data-aos-delay="260">
          <div class="channel-icon-wrap"><i data-lucide="thumbs-up" style={{ width: "24px", height: "24px" }}></i></div>
          <h3 class="channel-name">Reporte de Buenas Prácticas</h3>
          <p class="channel-desc">Reconocemos el valor de cuidar lo nuestro. Reporta acciones que preservan nuestros recursos.</p>
          <a href="https://formularios-inacons.bitrix24.site/reporte-buenas-practicas/" target="_blank" class="channel-btn">
            Ingresar al formulario <i data-lucide="external-link" style={{ width: "13px", height: "13px" }}></i>
          </a>
        </div>
        <div class="channel-card" data-aos="fade-up" data-aos-delay="320">
          <div class="channel-icon-wrap"><i data-lucide="message-square" style={{ width: "24px", height: "24px" }}></i></div>
          <h3 class="channel-name">Reporte de Quejas</h3>
          <p class="channel-desc">Tu satisfacción nos importa. Si algo no cumple con nuestros estándares, utiliza este canal.</p>
          <a href="https://formularios-inacons.bitrix24.site/reporte-quejas/" target="_blank" class="channel-btn">
            Ingresar al formulario <i data-lucide="external-link" style={{ width: "13px", height: "13px" }}></i>
          </a>
        </div>
        <div class="channel-card" data-aos="fade-up" data-aos-delay="380">
          <div class="channel-icon-wrap"><i data-lucide="hard-hat" style={{ width: "24px", height: "24px" }}></i></div>
          <h3 class="channel-name">Actos y Condiciones Subestándar</h3>
          <p class="channel-desc">Seguridad ante todo. Reporta cualquier condición física o acción que represente un riesgo de accidente.</p>
          <a href="https://formularios-inacons.bitrix24.site/reporte-actos-subestandar/" target="_blank" class="channel-btn">
            Ingresar al formulario <i data-lucide="external-link" style={{ width: "13px", height: "13px" }}></i>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Script del checkbox -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      const checkbox = document.getElementById('termsCheckbox');
      const channelsSection = document.getElementById('channelsSection');
      if (checkbox && channelsSection) {
        checkbox.addEventListener('change', function() {
          if (this.checked) {
            channelsSection.style.display = 'block';
            channelsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
          } else {
            channelsSection.style.display = 'none';
          }
        });
      }
    });
  </script>

</BaseLayout>