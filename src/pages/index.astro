  <!-- ⑥ CTA + FORMULARIO -->
  <section class="cta-band" id="quick-contact">
    <div class="container">
      <div class="cta-band-inner">
        <div data-aos="fade-right">
          <div class="sh sh--left sh--narrow">
            <p class="sh-label">¿Tienes un proyecto?</p>
            <h2 class="sh-title">¿Listo para iniciar su proyecto?</h2>
            <p class="sh-desc">Nuestro equipo de expertos está listo para asesorarlo en soluciones de ingeniería y
              construcción a medida.</p>
          </div>
          <div style="display:flex; gap:12px; flex-wrap:wrap; margin-top:32px;">
            <a href="/contacto" class="btn btn-primary">
              Contáctenos <i data-lucide="arrow-right" style={{ width: "15px", height: "15px" }}></i>
            </a>
            <a href="/brochure_inacons.pdf" target="_blank" class="btn btn-outline-light">
              <i data-lucide="download" style={{ width: "15px", height: "15px" }}></i> Brochure
            </a>
          </div>
        </div>
        <div data-aos="fade-left">
          <div class="form-card">
            <h3>Consulta Rápida</h3>
            <form action="https://formspree.io/f/mdapkgog" method="POST">
              <div class="form-row">
                <div class="form-group">
                  <input type="text" name="nombre" placeholder="Nombre completo" required class="form-input">
                </div>
                <div class="form-group">
                  <input type="email" name="email" placeholder="Correo corporativo" required class="form-input">
                </div>
              </div>
              <div class="form-group">
                <textarea name="mensaje" placeholder="¿En qué podemos ayudarle?" required class="form-textarea"></textarea>
              </div>
              <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">
                Enviar Consulta <i data-lucide="send" style={{ width: "14px", height: "14px" }}></i>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Inicializar Swiper del carousel -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      if (typeof Swiper !== 'undefined' && document.querySelector('.info-carousel-swiper')) {
        new Swiper('.info-carousel-swiper', {
          loop: true,
          slidesPerView: 1,
          autoplay: { delay: 5500, disableOnInteraction: false },
          navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
          pagination: { el: '.swiper-pagination', clickable: true },
        });
      }
    });
  </script>

