---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout titulo="Nosotros" descripcion="Conoce más sobre INACONS: nuestra misión, visión y los valores que nos han consolidado como líderes en construcción e ingeniería durante más de 15 años.">

  <style slot="head">
    /* Quiénes somos */
    .about-intro-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }
    .about-intro-img {
      position: relative;
      height: 500px;
    }
    .about-intro-img::before {
      content: '';
      position: absolute;
      top: -10px; left: -10px; right: 10px; bottom: 10px;
      border: 1.5px solid var(--c-border);
      border-radius: 2px;
      z-index: 0;
    }
    .about-intro-img img {
      position: relative; z-index: 1;
      width: 100%; height: 100%; object-fit: cover; border-radius: 2px;
    }
    .about-stat-row {
      display: flex; gap: 40px; margin-top: 40px;
    }
    .about-stat strong {
      display: block;
      font-size: 2.2rem; font-weight: 800;
      color: var(--c-primary); letter-spacing: -1px; line-height: 1;
    }
    .about-stat span {
      font-size: 0.78rem; color: var(--c-text-muted);
      font-weight: 500; text-transform: uppercase; letter-spacing: 1px;
    }

    /* Misión / Visión / Valores */
    .mvv-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 80px;
      align-items: start;
    }
    .mvv-img {
      position: sticky; top: 120px;
      height: 520px; border-radius: 2px; overflow: hidden;
    }
    .mvv-img img { width: 100%; height: 100%; object-fit: cover; }
    .mvv-block {
      padding: 28px 0;
      border-top: 1px solid var(--c-border-light);
    }
    .mvv-block:first-child { border-top: none; padding-top: 0; }
    .mvv-label {
      font-size: 0.65rem; font-weight: 700; letter-spacing: 2.5px;
      text-transform: uppercase; color: var(--c-secondary);
      margin-bottom: 10px;
    }
    .mvv-title {
      font-size: 1.15rem; font-weight: 700;
      color: var(--c-text-heading); margin-bottom: 12px;
    }
    .mvv-desc {
      font-size: 0.88rem; color: var(--c-text-muted); line-height: 1.8;
    }
    .valores-list {
      display: flex; flex-wrap: wrap; gap: 10px; margin-top: 16px;
    }
    .valor-tag {
      display: inline-block;
      padding: 6px 16px;
      font-size: 0.75rem; font-weight: 700; letter-spacing: 0.5px;
      border: 1.5px solid var(--c-border);
      color: var(--c-text-heading); border-radius: 2px;
    }

    /* Por qué INACONS */
    .pillars-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 3px;
      margin-top: 48px;
    }
    .pillar-card {
      padding: 40px 28px;
      background: var(--c-bg-white);
      border: 1px solid var(--c-border-light);
      position: relative;
    }
    .pillar-card::before {
      content: '';
      position: absolute; top: 0; left: 0;
      width: 100%; height: 3px;
      background: var(--c-border-light);
      transition: background .25s;
    }
    .pillar-card:hover::before { background: var(--c-secondary); }
    .pillar-num {
      font-size: 3rem; font-weight: 800;
      color: rgba(20,23,45,0.05);
      line-height: 1; margin-bottom: 20px;
      letter-spacing: -2px;
    }
    .pillar-title {
      font-size: 1rem; font-weight: 700;
      color: var(--c-text-heading); margin-bottom: 12px;
    }
    .pillar-desc {
      font-size: 0.83rem; color: var(--c-text-muted); line-height: 1.75;
    }

    @media (max-width: 1023px) {
      .about-intro-grid { grid-template-columns: 1fr; gap: 40px; }
      .about-intro-img { height: 360px; }
      .mvv-grid { grid-template-columns: 1fr; }
      .mvv-img { position: relative; top: 0; height: 280px; }
      .pillars-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 640px) {
      .pillars-grid { grid-template-columns: 1fr; }
      .about-stat-row { flex-wrap: wrap; gap: 24px; }
    }
  </style>

  <!-- HERO -->
  <section class="page-hero page-hero--sm">
    <div class="page-hero-bg" style="background-image: url('/assets/imagenes/image_nosotros.webp');"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content" data-aos="fade-up" data-aos-duration="800">
      <nav class="breadcrumb">
        <a href="/">Inicio</a>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-current">Nosotros</span>
      </nav>
      <h1 class="page-hero-title">Comprometidos con la<br>Excelencia en Construcción</h1>
      <p class="page-hero-subtitle">Más de 15 años construyendo confianza en el Perú</p>
    </div>
  </section>

  <!-- QUIÉNES SOMOS -->
  <section class="sec sec--white">
    <div class="container">
      <div class="about-intro-grid">
        <div data-aos="fade-right">
          <div class="sh">
            <p class="sh-label">Quiénes Somos</p>
            <h2 class="sh-title">Una empresa construida sobre confianza y resultados</h2>
          </div>
          <p style="font-size:0.93rem;color:var(--c-text-body);line-height:1.85;margin-bottom:20px;">
            Somos INACONS, una empresa con más de 15 años de experiencia en ingeniería y construcción en el Perú. Desarrollamos proyectos de alta complejidad con los más altos estándares de calidad, seguridad y sostenibilidad.
          </p>
          <p style="font-size:0.93rem;color:var(--c-text-body);line-height:1.85;margin-bottom:36px;">
            Nuestro equipo multidisciplinario, conformado por más de 200 profesionales, nos permite ofrecer soluciones especializadas y cumplir con nuestra misión: transformar espacios y construir confianza en cada proyecto.
          </p>
          <div class="about-stat-row">
            <div class="about-stat">
              <strong data-counter="15" data-suffix="+">0+</strong>
              <span>Años de experiencia</span>
            </div>
            <div class="about-stat">
              <strong data-counter="200" data-suffix="+">0+</strong>
              <span>Profesionales</span>
            </div>
            <div class="about-stat">
              <strong data-counter="150" data-suffix="+">0+</strong>
              <span>Proyectos ejecutados</span>
            </div>
          </div>
          <a href="/contacto" class="btn btn-primary" style="margin-top:36px;display:inline-flex;align-items:center;gap:8px;">
            Trabajemos juntos <i data-lucide="arrow-right" style={{ width:"14px",height:"14px" }}></i>
          </a>
        </div>
        <div class="about-intro-img" data-aos="fade-left">
          <img src="/assets/imagenes/about_section.webp" alt="Equipo INACONS en obra" />
        </div>
      </div>
    </div>
  </section>

  <!-- MISIÓN / VISIÓN / VALORES -->
  <section class="sec sec--muted">
    <div class="container">
      <div class="mvv-grid">
        <div>
          <div class="sh" data-aos="fade-up">
            <p class="sh-label">Ingeniería que Construye</p>
            <h2 class="sh-title">Principios que guían cada proyecto</h2>
          </div>
          <div class="mvv-block" data-aos="fade-up" data-aos-delay="80">
            <p class="mvv-label">Misión</p>
            <h3 class="mvv-title">Generamos valor en cada obra</h3>
            <p class="mvv-desc">Fortalecernos responsablemente generando valor de nuestros servicios de ingeniería y construcción, cumpliendo nuestro propósito a todos nuestros clientes y socios estratégicos.</p>
          </div>
          <div class="mvv-block" data-aos="fade-up" data-aos-delay="160">
            <p class="mvv-label">Visión</p>
            <h3 class="mvv-title">Referentes en Latinoamérica</h3>
            <p class="mvv-desc">Ser reconocidos como la empresa de ingeniería y construcción sólida capaz de diversificar nuestros servicios en la región Latinoamérica, comprometidos con el desarrollo sostenible de todos nuestros clientes y socios estratégicos.</p>
          </div>
          <div class="mvv-block" data-aos="fade-up" data-aos-delay="240">
            <p class="mvv-label">Valores</p>
            <h3 class="mvv-title">Lo que nos define como equipo</h3>
            <div class="valores-list">
              <span class="valor-tag">Confianza</span>
              <span class="valor-tag">Innovación</span>
              <span class="valor-tag">Trascender</span>
              <span class="valor-tag">Lealtad</span>
              <span class="valor-tag">Identificación</span>
            </div>
          </div>
        </div>
        <div class="mvv-img" data-aos="fade-left">
          <img src="/assets/imagenes/about_team.webp" alt="Equipo INACONS" />
        </div>
      </div>
    </div>
  </section>

  <!-- POR QUÉ INACONS -->
  <section class="sec sec--white">
    <div class="container">
      <div class="sh sh--center sh--medium" data-aos="fade-up">
        <p class="sh-label">Lo que nos diferencia</p>
        <h2 class="sh-title">Por qué elegir INACONS</h2>
        <p class="sh-desc">Cuatro pilares que definen nuestra forma de trabajar y nos distinguen como líderes en el sector de la construcción e ingeniería.</p>
      </div>
      <div class="pillars-grid">
        <div class="pillar-card" data-aos="fade-up" data-aos-delay="80">
          <div class="pillar-num">01</div>
          <h3 class="pillar-title">Experiencia</h3>
          <p class="pillar-desc">Más de 15 años de trayectoria nos respaldan como líderes en el sector, desarrollando proyectos innovadores y sostenibles a lo largo de todo el Perú.</p>
        </div>
        <div class="pillar-card" data-aos="fade-up" data-aos-delay="160">
          <div class="pillar-num">02</div>
          <h3 class="pillar-title">Innovación y Sostenibilidad</h3>
          <p class="pillar-desc">Implementamos las últimas tecnologías y prácticas sostenibles para crear espacios que respeten el medio ambiente y mejoren la calidad de vida.</p>
        </div>
        <div class="pillar-card" data-aos="fade-up" data-aos-delay="240">
          <div class="pillar-num">03</div>
          <h3 class="pillar-title">Orientación al Cliente</h3>
          <p class="pillar-desc">Nuestro compromiso es superar las expectativas de cada cliente, brindando soluciones personalizadas y un servicio de excelencia en cada proyecto.</p>
        </div>
        <div class="pillar-card" data-aos="fade-up" data-aos-delay="320">
          <div class="pillar-num">04</div>
          <h3 class="pillar-title">Equipo Humano</h3>
          <p class="pillar-desc">Contamos con un equipo multicultural que se adapta a cualquier contexto y tiene la experiencia para enfrentar todo tipo de retos con excelencia.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    const counters = document.querySelectorAll('[data-counter]');
    if (!counters.length) return;

    const animateCounter = (el) => {
      const target = parseInt(el.getAttribute('data-counter'));
      const suffix = el.getAttribute('data-suffix') || '';
      const duration = 1800;
      const start = performance.now();

      const ease = (t) => t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;

      const update = (now) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const value = Math.floor(ease(progress) * target);
        el.textContent = value + suffix;
        if (progress < 1) requestAnimationFrame(update);
        else el.textContent = target + suffix;
      };

      requestAnimationFrame(update);
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCounter(entry.target);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });

    counters.forEach(el => observer.observe(el));
  });
</script>