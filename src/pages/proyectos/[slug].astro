---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

type Proyecto = CollectionEntry<'proyectos'>;

export async function getStaticPaths() {
  const proyectos = await getCollection('proyectos');
  return proyectos.map((proyecto: Proyecto) => ({
    params: { slug: proyecto.id },
    props:  { proyecto },
  }));
}

interface Props {
  proyecto: Proyecto;
}

const { proyecto } = Astro.props;
const { Content } = await render(proyecto);
const { titulo, ubicacion, categoria, año, imagen, galeria = [] } = proyecto.data;

// Proyectos relacionados — misma categoría
const todosProyectos = await getCollection('proyectos');
const relacionados = todosProyectos
  .filter((p: Proyecto) => p.id !== proyecto.id && p.data.categoria === categoria)
  .slice(0, 3);
---

<BaseLayout titulo={titulo} descripcion={`${categoria} en ${ubicacion} — ${año}`}>

  <!-- HERO -->
  <section class="page-hero">
    <div class="page-hero-bg" style={`background-image: url('${imagen}')`}></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a>
        <span class="breadcrumb-sep">›</span>
        <a href="/proyectos">Proyectos</a>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-current">{titulo}</span>
      </nav>
      <h1 class="page-hero-title">{titulo}</h1>
      <p class="page-hero-subtitle">{ubicacion} — {año}</p>
    </div>
  </section>

  <!-- CONTENIDO -->
  <section class="sec sec--white">
    <div class="container">
      <div class="proyecto-layout">

        <!-- Columna principal -->
        <div class="proyecto-body" data-aos="fade-up">

          <!-- Badge de categoría -->
          <span class="proyecto-badge">{categoria}</span>

          <!-- Contenido del .md -->
          <Content />

          <!-- Galería de fotos -->
          {galeria.length > 0 && (
            <div class="galeria">
              <div class="galeria-principal">
                <img src={galeria[0]} alt={`${titulo} — foto 1`} loading="lazy" />
              </div>
              {galeria.length > 1 && (
                <div class="galeria-thumbs">
                  {galeria.slice(1).map((foto: string, i: number) => (
                    <div class="galeria-thumb">
                      <img src={foto} alt={`${titulo} — foto ${i + 2}`} loading="lazy" />
                    </div>
                  ))}
                </div>
              )}
            </div>
          )}

          <a href="/contacto" class="btn btn-primary">
            Consultar proyecto similar
            <i data-lucide="arrow-right" style={{ width: "15px", height: "15px" }}></i>
          </a>
        </div>

        <!-- Ficha técnica -->
        <aside class="proyecto-aside">
          <div class="aside-card" data-aos="fade-left">
            <p class="aside-card-title">Ficha Técnica</p>
            <div class="ficha">
              <div class="ficha-item">
                <span class="ficha-label">Ubicación</span>
                <span class="ficha-value">{ubicacion}</span>
              </div>
              <div class="ficha-item">
                <span class="ficha-label">Categoría</span>
                <span class="ficha-value">{categoria}</span>
              </div>
              <div class="ficha-item">
                <span class="ficha-label">Año</span>
                <span class="ficha-value">{año}</span>
              </div>
            </div>
          </div>

          {relacionados.length > 0 && (
            <div class="aside-card" data-aos="fade-left" data-aos-delay="100">
              <p class="aside-card-title">Proyectos relacionados</p>
              <nav>
                {relacionados.map((p: Proyecto) => (
                  <a href={`/proyectos/${p.id}`} class="related-link">
                    <div class="related-thumb">
                      <img src={p.data.imagen} alt={p.data.titulo} loading="lazy" />
                    </div>
                    <div class="related-info">
                      <span class="related-name">{p.data.titulo}</span>
                      <span class="related-meta">{p.data.ubicacion} — {p.data.año}</span>
                    </div>
                  </a>
                ))}
              </nav>
            </div>
          )}
        </aside>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="sec sec--dark">
    <div class="container">
      <div class="sh sh--center sh--medium">
        <p class="sh-label">¿Proyecto similar?</p>
        <h2 class="sh-title">¿Tienes un proyecto que requiere nuestra experiencia?</h2>
        <p class="sh-desc">
          Contamos con el equipo y la metodología para llevar
          tu proyecto al más alto nivel de calidad.
        </p>
      </div>
      <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap; margin-top:36px;">
        <a href="/contacto" class="btn btn-primary btn-lg">
          Solicitar propuesta
          <i data-lucide="send" style={{ width: "15px", height: "15px" }}></i>
        </a>
        <a href="/proyectos" class="btn btn-outline-light btn-lg">
          Ver todos los proyectos
          <i data-lucide="arrow-right" style={{ width: "15px", height: "15px" }}></i>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .proyecto-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 64px;
    align-items: start;
  }

  /* Badge */
  .proyecto-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 14px;
    background: rgba(27,82,120,0.09);
    border: 1px solid rgba(27,82,120,0.20);
    border-radius: var(--radius);
    font-size: 0.70rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--c-secondary);
    margin-bottom: 24px;
  }

  /* Contenido del .md */
  .proyecto-body h2 {
    font-size: clamp(1.3rem, 2.2vw, 1.7rem);
    font-weight: 700;
    color: var(--c-text-heading);
    margin: 32px 0 16px;
  }

  .proyecto-body p {
    font-size: 0.975rem;
    line-height: 1.85;
    color: var(--c-text-body);
    margin-bottom: 18px;
  }

  .proyecto-body ul {
    list-style: none;
    padding: 0;
    margin: 0 0 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .proyecto-body ul li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.90rem;
    color: var(--c-text-body);
  }

  .proyecto-body ul li::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--c-secondary);
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 7px;
  }

  /* Galería */
  .galeria { margin: 36px 0; }

  .galeria-principal {
    width: 100%;
    height: 400px;
    overflow: hidden;
    margin-bottom: 3px;
  }

  .galeria-principal img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .6s ease;
  }

  .galeria-principal:hover img { transform: scale(1.03); }

  .galeria-thumbs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
  }

  .galeria-thumb {
    height: 120px;
    overflow: hidden;
  }

  .galeria-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.85);
    transition: filter .3s, transform .4s;
  }

  .galeria-thumb:hover img {
    filter: brightness(1);
    transform: scale(1.05);
  }

  /* Aside */
  .proyecto-aside {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .aside-card {
    background: var(--c-bg-white);
    border: 1px solid var(--c-border-light);
    padding: 28px 24px;
    position: relative;
  }

  .aside-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 100%;
    background: var(--c-secondary);
  }

  .aside-card-title {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--c-text-muted);
    margin-bottom: 16px;
  }

  /* Ficha técnica */
  .ficha { display: flex; flex-direction: column; }

  .ficha-item {
    display: flex;
    flex-direction: column;
    padding: 11px 0;
    border-bottom: 1px solid var(--c-border-light);
  }

  .ficha-item:last-child { border-bottom: none; }

  .ficha-label {
    font-size: 0.63rem;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--c-text-muted);
    margin-bottom: 2px;
  }

  .ficha-value {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--c-text-heading);
  }

  /* Relacionados */
  .related-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    text-decoration: none;
    border-bottom: 1px solid var(--c-border-light);
    transition: padding-left var(--t);
  }

  .related-link:last-child { border-bottom: none; }
  .related-link:hover { padding-left: 4px; }

  .related-thumb {
    width: 52px;
    height: 40px;
    border-radius: var(--radius);
    overflow: hidden;
    flex-shrink: 0;
  }

  .related-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .related-name {
    display: block;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--c-text-heading);
    line-height: 1.3;
    transition: color var(--t);
  }

  .related-link:hover .related-name { color: var(--c-secondary); }

  .related-meta {
    display: block;
    font-size: 0.70rem;
    color: var(--c-text-muted);
    margin-top: 2px;
  }

  /* Responsive */
  @media (max-width: 1023px) {
    .proyecto-layout { grid-template-columns: 1fr; gap: 48px; }
    .proyecto-aside  { position: static; }
    .galeria-principal { height: 280px; }
  }

  @media (max-width: 768px) {
    .galeria-thumbs { grid-template-columns: repeat(2, 1fr); }
    .galeria-thumb  { height: 100px; }
  }
</style>