---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

type Proyecto = CollectionEntry<'proyectos'>;

const proyectos = await getCollection('proyectos');
proyectos.sort((a: Proyecto, b: Proyecto) =>
  (a.data.orden ?? 99) - (b.data.orden ?? 99)
);
---

<BaseLayout titulo="Proyectos" descripcion="Proyectos ejecutados por INACONS a nivel nacional">

  <section class="page-hero page-hero--sm">
    <div class="page-hero-bg" style="background-image: url('/assets/imagenes/hero_project.png')"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <nav class="breadcrumb">
        <a href="/">Inicio</a>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-current">Proyectos</span>
      </nav>
      <h1 class="page-hero-title">Nuestros Proyectos</h1>
      <p class="page-hero-subtitle">Obras ejecutadas a lo largo de todo el territorio peruano</p>
    </div>
  </section>

  <section class="sec sec--muted">
    <div class="container">

      <div class="sh sh--center sh--medium">
        <p class="sh-label">Portafolio</p>
        <h2 class="sh-title">Lo que hemos construido</h2>
        <p class="sh-desc">
          Más de 15 años ejecutando proyectos de alta complejidad
          para clientes del sector público y privado.
        </p>
      </div>

      <div class="proyectos-grid">
        {proyectos.map((proyecto: Proyecto) => (
          <a href={`/proyectos/${proyecto.id}`} class="proyecto-card">
            <div class="proyecto-img">
              <img src={proyecto.data.imagen} alt={proyecto.data.titulo} loading="lazy" />
            </div>
            <div class="proyecto-info">
              <span class="proyecto-cat">{proyecto.data.categoria}</span>
              <h2>{proyecto.data.titulo}</h2>
              <p>{proyecto.data.ubicacion} — {proyecto.data.año}</p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .proyectos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
  }

  .proyecto-card {
    position: relative;
    height: 420px;
    overflow: hidden;
    text-decoration: none;
    display: block;
  }

  .proyecto-img {
    position: absolute;
    inset: 0;
  }

  .proyecto-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .proyecto-card:hover .proyecto-img img {
    transform: scale(1.05);
  }

  .proyecto-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(20,23,45,0.10) 0%,
      rgba(20,23,45,0.90) 100%
    );
  }

  .proyecto-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 28px 24px;
    z-index: 2;
  }

  .proyecto-cat {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.60);
    margin-bottom: 8px;
  }

  .proyecto-info h2 {
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 6px;
    line-height: 1.3;
  }

  .proyecto-info p {
    font-size: 0.80rem;
    color: rgba(255,255,255,0.55);
    margin: 0;
  }

  @media (max-width: 1023px) {
    .proyectos-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .proyectos-grid { grid-template-columns: 1fr; }
    .proyecto-card  { height: 320px; }
  }
</style>