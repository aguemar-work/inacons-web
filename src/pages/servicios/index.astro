---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

type Servicio = CollectionEntry<'servicios'>;

const servicios = await getCollection('servicios');
servicios.sort((a: Servicio, b: Servicio) =>
  (a.data.orden ?? 99) - (b.data.orden ?? 99)
);
---

<BaseLayout titulo="Operaciones" descripcion="Soluciones integrales en ingeniería y construcción para los sectores público y privado a nivel nacional.">

  <!-- HERO -->
  <section class="page-hero page-hero--sm">
    <div class="page-hero-bg" style="background-image: url('/assets/imagenes/image_infraestructura.webp');"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content" data-aos="fade-up" data-aos-duration="800">
      <nav class="breadcrumb">
        <a href="/">Inicio</a>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-current">Operaciones</span>
      </nav>
      <h1 class="page-hero-title">Agregamos valor<br>en cada etapa</h1>
      <p class="page-hero-subtitle">Soluciones integrales desde la planificación hasta la entrega final</p>
    </div>
  </section>

  <!-- GRID DE SERVICIOS -->
  <section class="sec sec--muted">
    <div class="container">

      <div class="sh sh--center sh--medium" data-aos="fade-up">
        <p class="sh-label">Lo que hacemos</p>
        <h2 class="sh-title">Nuestras Operaciones</h2>
        <p class="sh-desc">
          Ofrecemos servicios especializados que cubren todas las etapas de construcción, desde la planificación hasta la ejecución final.
        </p>
      </div>

      <div class="services-grid">
        {servicios.map((servicio: Servicio) => (
          <a href={`/servicios/${servicio.id}`} class="service-item">
            <div class="service-img">
              <img src={servicio.data.imagen} alt={servicio.data.titulo} loading="lazy" />
            </div>
            <div class="service-info">
              <h2>{servicio.data.titulo}</h2>
              <p>{servicio.data.descripcion}</p>
              <span class="btn btn-outline btn-sm">
                Ver más <i data-lucide="arrow-right" style={{ width: "14px", height: "14px" }}></i>
              </span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- PROCESO -->
  <section class="sec sec--white">
    <div class="container">
      <div class="sh sh--center sh--medium" data-aos="fade-up">
        <p class="sh-label">Nuestro Proceso</p>
        <h2 class="sh-title">Metodología de trabajo</h2>
        <p class="sh-desc">Cada proyecto sigue un proceso riguroso de cuatro etapas que garantiza calidad, cumplimiento de plazos y satisfacción total del cliente.</p>
      </div>
      <div class="process-grid">
        <div class="process-step" data-aos="fade-up" data-aos-delay="80">
          <div class="process-num">01</div>
          <h3 class="process-title">Descubrimiento</h3>
          <p class="process-desc">Analizamos a fondo las necesidades del proyecto, realizamos estudios de factibilidad y evaluamos todos los aspectos técnicos y normativos.</p>
        </div>
        <div class="process-step" data-aos="fade-up" data-aos-delay="160">
          <div class="process-num">02</div>
          <h3 class="process-title">Planificación y Diseño</h3>
          <p class="process-desc">Desarrollamos planos detallados, cronogramas de trabajo y especificaciones técnicas, asegurando coordinación perfecta antes de la ejecución.</p>
        </div>
        <div class="process-step" data-aos="fade-up" data-aos-delay="240">
          <div class="process-num">03</div>
          <h3 class="process-title">Ejecución</h3>
          <p class="process-desc">Implementamos el proyecto con equipos especializados, supervisión constante y control de calidad en cada etapa, con los más altos estándares.</p>
        </div>
        <div class="process-step" data-aos="fade-up" data-aos-delay="320">
          <div class="process-num">04</div>
          <h3 class="process-title">Entrega y Seguimiento</h3>
          <p class="process-desc">Realizamos pruebas finales, entregamos la obra completamente funcional y brindamos soporte post-entrega para garantizar la satisfacción total.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TECNOLOGÍA -->
  <section class="sec sec--muted">
    <div class="container">
      <div class="sh sh--center sh--medium" data-aos="fade-up">
        <p class="sh-label">Tecnología</p>
        <h2 class="sh-title">Innovación aplicada a cada proyecto</h2>
        <p class="sh-desc">Incorporamos las últimas herramientas tecnológicas para optimizar procesos, reducir errores y entregar resultados superiores.</p>
      </div>
      <div class="tech-grid">
        <div class="tech-card" data-aos="fade-up" data-aos-delay="80">
          <div class="tech-img">
            <img src="/assets/imagenes/tecnologia_control.jpg" alt="Supervisión Inteligente INACONS" loading="lazy" />
          </div>
          <div class="tech-content">
            <p class="tech-label">Supervisión Inteligente</p>
            <h3 class="tech-title">Tecnología Aplicada a Supervisión y Control</h3>
            <p class="tech-desc">Control de Asistencia · Documentos Digitales · Drones · Lidar · Supervisión en tiempo real para mayor eficiencia y trazabilidad.</p>
          </div>
        </div>
        <div class="tech-card" data-aos="fade-up" data-aos-delay="200">
          <div class="tech-img">
            <img src="/assets/imagenes/tecnologia_bim.jpg" alt="Tecnología BIM INACONS" loading="lazy" />
          </div>
          <div class="tech-content">
            <p class="tech-label">Modelado Digital</p>
            <h3 class="tech-title">Tecnología BIM</h3>
            <p class="tech-desc">Impulsamos la gestión integral de proyectos con Building Information Modeling, mejorando eficiencia y coordinación en cada etapa del proceso.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
  }

  .service-item {
    position: relative;
    height: 420px;
    overflow: hidden;
    text-decoration: none;
    display: block;
  }

  .service-img {
    position: absolute;
    inset: 0;
  }

  .service-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .service-item:hover .service-img img {
    transform: scale(1.05);
  }

  .service-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(20,23,45,0.2) 0%,
      rgba(20,23,45,0.88) 100%
    );
  }

  .service-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 32px 28px;
    z-index: 2;
  }

  .service-info h2 {
    font-size: 1.3rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 10px;
  }

  .service-info p {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.72);
    line-height: 1.6;
    margin-bottom: 20px;
  }

  /* Proceso */
  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3px;
    margin-top: 48px;
  }

  .process-step {
    padding: 40px 28px;
    background: var(--c-bg-muted);
    border: 1px solid var(--c-border-light);
    position: relative;
  }

  .process-step::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 3px;
    background: var(--c-secondary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .3s ease;
  }

  .process-step:hover::before { transform: scaleX(1); }

  .process-num {
    font-size: 3.5rem; font-weight: 800;
    color: rgba(20,23,45,0.06);
    line-height: 1; margin-bottom: 16px;
    letter-spacing: -2px;
  }

  .process-title {
    font-size: 1rem; font-weight: 700;
    color: var(--c-text-heading); margin-bottom: 12px;
  }

  .process-desc {
    font-size: 0.83rem; color: var(--c-text-muted); line-height: 1.75;
  }

  /* Tecnología */
  .tech-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3px;
    margin-top: 48px;
  }

  .tech-card {
    background: var(--c-bg-white);
    border: 1px solid var(--c-border-light);
    overflow: hidden;
  }

  .tech-img {
    height: 260px;
    overflow: hidden;
  }

  .tech-img img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform .5s ease;
  }

  .tech-card:hover .tech-img img { transform: scale(1.04); }

  .tech-content { padding: 32px 32px 36px; }

  .tech-label {
    font-size: 0.65rem; font-weight: 700; letter-spacing: 2.5px;
    text-transform: uppercase; color: var(--c-secondary); margin-bottom: 10px;
  }

  .tech-title {
    font-size: 1.1rem; font-weight: 700;
    color: var(--c-text-heading); margin-bottom: 14px;
  }

  .tech-desc {
    font-size: 0.85rem; color: var(--c-text-muted); line-height: 1.8;
  }

  @media (max-width: 1023px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
    .process-grid { grid-template-columns: repeat(2, 1fr); }
    .tech-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .services-grid { grid-template-columns: 1fr; }
    .service-item  { height: 320px; }
    .process-grid { grid-template-columns: 1fr; }
  }
</style>