---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout titulo="Sostenibilidad" descripcion="Responsabilidad social, seguridad y desarrollo sostenible en cada proyecto de INACONS">

  <style slot="head">
    .split-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }
    .split-img { position: relative; height: 480px; overflow: hidden; border-radius: 2px; }
    .split-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s ease; }
    .split-img:hover img { transform: scale(1.03); }
    .split-right .split-img { order: 2; }
    .split-right .split-text { order: 1; }
    .safety-chips { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 28px; }
    .safety-chip {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 18px;
      border: 1.5px solid var(--c-border);
      border-radius: 2px;
      font-size: 0.78rem; font-weight: 600;
      color: var(--c-text-heading);
      background: var(--c-bg-white);
      transition: border-color .22s, background .22s, color .22s;
    }
    .safety-chip:hover { border-color: var(--c-secondary); background: rgba(27,82,120,0.05); color: var(--c-secondary); }
    .safety-chip i { color: var(--c-secondary); }
    .ods-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-top: 48px; }
    .ods-card {
      background: var(--c-bg-white);
      border: 1px solid var(--c-border-light);
      border-radius: 2px; padding: 32px 24px; text-align: center;
      transition: box-shadow .24s, transform .24s, border-color .24s;
    }
    .ods-card:hover { box-shadow: var(--shadow-card-hover); transform: translateY(-4px); border-color: var(--c-secondary); }
    .ods-icon {
      width: 56px; height: 56px;
      background: var(--c-bg-muted); border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: var(--c-secondary); margin: 0 auto 16px;
      transition: background .24s, color .24s;
    }
    .ods-card:hover .ods-icon { background: var(--c-secondary); color: #fff; }
    .ods-title { font-size: 0.88rem; font-weight: 700; color: var(--c-text-heading); margin-bottom: 8px; }
    .ods-desc { font-size: 0.80rem; color: var(--c-text-muted); line-height: 1.7; }
    @media (max-width: 768px) {
      .split-grid { grid-template-columns: 1fr; gap: 36px; }
      .split-img { height: 260px; }
      .split-right .split-img, .split-right .split-text { order: 0; }
      .ods-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
    }
    @media (min-width: 769px) and (max-width: 1023px) {
      .split-grid { gap: 48px; }
      .split-img { height: 360px; }
      .ods-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>

  <!-- HERO -->
  <section class="page-hero">
    <div class="page-hero-bg" style="background-image: url('/assets/imagenes/sostenibilidad.png')"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content" data-aos="fade-up" data-aos-duration="800">
      <nav class="breadcrumb">
        <a href="/">Inicio</a>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-current">Sostenibilidad</span>
      </nav>
      <h1 class="page-hero-title">Construyendo<br>un futuro mejor</h1>
      <p class="page-hero-subtitle">Responsabilidad social, seguridad y desarrollo sostenible en cada proyecto</p>
    </div>
  </section>

  <!-- ① COMPROMISO SOCIAL -->
  <section class="sec sec--white">
    <div class="container">
      <div class="split-grid split-right">
        <div class="split-text" data-aos="fade-right" data-aos-duration="800">
          <div class="sh sh--left sh--narrow">
            <p class="sh-label">Responsabilidad Social</p>
            <h2 class="sh-title">Nuestro Compromiso Social</h2>
            <p class="sh-desc">En INACONS apoyamos activamente a las comunidades. A través de nuestra colaboración con Aldeas Infantiles, contribuimos al bienestar de niños y familias en situación de vulnerabilidad.</p>
            <p class="sh-desc" style="margin-top:-8px;">Nuestra labor va más allá de la construcción: trabajamos con ética y responsabilidad, alineados con los Objetivos de Desarrollo Sostenible (ODS).</p>
          </div>
          <a href="/contacto" class="btn btn-primary">
            Conoce más <i data-lucide="arrow-right" width={15} height={15}></i>
          </a>
        </div>
        <div class="split-img" data-aos="fade-left" data-aos-duration="800">
          <img src="/assets/imagenes/aldeas_infantiles.jpg" alt="Compromiso Social INACONS" />
        </div>
      </div>
    </div>
  </section>

  <!-- ② SEGURIDAD -->
  <section class="sec sec--muted">
    <div class="container">
      <div class="split-grid">
        <div class="split-img" data-aos="fade-right" data-aos-duration="800">
          <img src="/assets/imagenes/seguridad.PNG" alt="Seguridad y Prevención INACONS" />
        </div>
        <div class="split-text" data-aos="fade-left" data-aos-duration="800">
          <div class="sh sh--left sh--narrow">
            <p class="sh-label">Cultura de Seguridad</p>
            <h2 class="sh-title">Seguridad y Prevención</h2>
            <p class="sh-desc">En INACONS aplicamos una política de cero accidentes, asegurando la seguridad y bienestar de cada colaborador. Desarrollamos iniciativas de reconocimiento, orden en obra y participación de todas las áreas en la prevención.</p>
          </div>
          <div class="safety-chips">
            <div class="safety-chip"><i data-lucide="shield-check" width={16} height={16}></i> Cero Accidentes</div>
            <div class="safety-chip"><i data-lucide="users" width={16} height={16}></i> Cultura Preventiva</div>
            <div class="safety-chip"><i data-lucide="award" width={16} height={16}></i> Reconocimientos</div>
            <div class="safety-chip"><i data-lucide="clipboard-check" width={16} height={16}></i> Orden en Obra</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ③ ODS -->
  <section class="sec sec--white">
    <div class="container">
      <div class="sh sh--center sh--medium" data-aos="fade-up">
        <p class="sh-label">Agenda 2030</p>
        <h2 class="sh-title">Objetivos de Desarrollo Sostenible</h2>
        <p class="sh-desc">Nuestras operaciones están alineadas con los ODS de las Naciones Unidas, integrando sostenibilidad en cada etapa de nuestros proyectos.</p>
      </div>
      <div class="ods-grid">
        <div class="ods-card" data-aos="fade-up" data-aos-delay="100">
          <div class="ods-icon"><i data-lucide="building-2" width={26} height={26}></i></div>
          <p class="ods-title">Industria e Infraestructura</p>
          <p class="ods-desc">Construimos infraestructura resiliente que impulsa el desarrollo económico.</p>
        </div>
        <div class="ods-card" data-aos="fade-up" data-aos-delay="180">
          <div class="ods-icon"><i data-lucide="leaf" width={26} height={26}></i></div>
          <p class="ods-title">Acción por el Clima</p>
          <p class="ods-desc">Reducimos el impacto ambiental incorporando prácticas sostenibles en obra.</p>
        </div>
        <div class="ods-card" data-aos="fade-up" data-aos-delay="260">
          <div class="ods-icon"><i data-lucide="users" width={26} height={26}></i></div>
          <p class="ods-title">Trabajo Decente</p>
          <p class="ods-desc">Generamos empleo digno y seguro para comunidades locales en cada proyecto.</p>
        </div>
        <div class="ods-card" data-aos="fade-up" data-aos-delay="340">
          <div class="ods-icon"><i data-lucide="heart-handshake" width={26} height={26}></i></div>
          <p class="ods-title">Reducción de Desigualdades</p>
          <p class="ods-desc">Apoyamos comunidades vulnerables a través de programas de responsabilidad social.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>